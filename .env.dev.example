# -------------------------------------------------------
# DataLoader — DEV environment
# Copy to .env.dev and fill in real values.
# Never commit .env.dev — it is gitignored.
# -------------------------------------------------------

# AWS
AWS_REGION=ap-south-1
S3_BUCKET=<aqilliz-dev-s3-bucket-name>

# Cognito (backend — same pool, dev App Client)
COGNITO_USER_POOL_ID=<pool-id>
COGNITO_APP_CLIENT_ID=<dev-app-client-id>

# RDS (existing Aqilliz DB — dev database)
DB_HOST=<rds-endpoint>
DB_PORT=5432
DB_NAME=dataloader_dev
DB_USER=<db-user>
DB_PASSWORD=<db-password>

# Frontend Cognito (baked into React build — same pool, dev App Client)
VITE_COGNITO_USER_POOL_ID=<pool-id>
VITE_COGNITO_APP_CLIENT_ID=<dev-app-client-id>
VITE_COGNITO_DOMAIN=<cognito-hosted-ui-domain>

# Port nginx exposes on the EC2 host
APP_PORT=8080
