# -------------------------------------------------------
# DataLoader — QA environment
# Copy to .env.qa and fill in real values.
# Never commit .env.qa — it is gitignored.
# -------------------------------------------------------

# AWS
AWS_REGION=ap-south-1
S3_BUCKET=<aqilliz-qa-s3-bucket-name>

# Cognito (backend — same pool, QA App Client)
COGNITO_USER_POOL_ID=<pool-id>
COGNITO_APP_CLIENT_ID=<qa-app-client-id>

# RDS (existing Aqilliz DB — QA database)
DB_HOST=<rds-endpoint>
DB_PORT=5432
DB_NAME=dataloader_qa
DB_USER=<db-user>
DB_PASSWORD=<db-password>

# Frontend Cognito (baked into React build — same pool, QA App Client)
VITE_COGNITO_USER_POOL_ID=<pool-id>
VITE_COGNITO_APP_CLIENT_ID=<qa-app-client-id>
VITE_COGNITO_DOMAIN=<cognito-hosted-ui-domain>

# Port nginx exposes on the EC2 host
APP_PORT=8081
