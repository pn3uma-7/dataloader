# AWS
AWS_REGION=ap-south-1
S3_BUCKET=TODO_your-private-data-bucket-name

# Cognito — required for JWT validation (both dev and prod)
COGNITO_USER_POOL_ID=TODO_ap-south-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=TODO_xxxxxxxxxxxxxxxxxxxx

# RDS — fetched from Secrets Manager in prod (set RDS_SECRET_ARN)
# For local dev against a real RDS or local Postgres, set the DB_* vars instead
RDS_SECRET_ARN=
DB_HOST=TODO_your-rds-endpoint.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=dataloader
DB_USER=dataloader_user
DB_PASSWORD=TODO_your-db-password

# Server
PORT=3000
NODE_ENV=development

# Only used when NODE_ENV=development AND Cognito vars are NOT set (pure local mock)
DEV_USER_EMAIL=dev@localhost
